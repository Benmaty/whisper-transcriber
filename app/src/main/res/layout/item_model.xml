<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/card_bg"
    android:layout_margin="4dp" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_model_name" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_model_description" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end|center_vertical">
            <TextView android:id="@+id/tv_model_size" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/accent_blue"
                android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_active_badge" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="ACTIF"
                android:textColor="@color/accent_green" android:textSize="10sp"
                android:layout_marginTop="4dp" android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
    <ProgressBar android:id="@+id/progress_model" style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="6dp"
        android:layout_marginTop="8dp" android:progressTint="@color/accent_blue"
        android:progressBackgroundTint="@color/surface_light" android:visibility="gone"/>
    <TextView android:id="@+id/tv_progress_text" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:gravity="center"
        android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="10dp" android:gravity="end">
        <Button android:id="@+id/btn_model_download" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Télécharger" android:textSize="12sp"
            android:backgroundTint="@color/accent_blue" android:textColor="@color/white"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_model_select" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Utiliser" android:textSize="12sp"
            android:backgroundTint="@color/accent_green" android:textColor="@color/white"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_model_delete" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Suppr." android:textSize="12sp"
            android:backgroundTint="@color/error_red" android:textColor="@color/white"/>
    </LinearLayout>
</LinearLayout>
